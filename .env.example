# =========================================================
# ОБЩИЕ НАСТРОЙКИ
# =========================================================

# Окружение ASP.NET Core.
# Определяет, какой appsettings.{Environment}.json будет использован
# и как будет вести себя приложение (логирование, ошибки и т.п.).
# Возможные значения: Development, Production
ASPNETCORE_ENVIRONMENT=Development


# =========================================================
# ПОРТЫ СЕРВИСОВ НА ХОСТЕ
# =========================================================

# Порт, по которому API будет доступен с хоста.
# Внутри контейнера API слушает на 8080, снаружи — на API_PORT.
# Пример: http://localhost:8080
API_PORT=8080

# Порт, по которому SPA (React + nginx) будет доступен с хоста.
# Внутри контейнера nginx слушает на 80, снаружи — на CLIENT_PORT.
# Пример: http://localhost:3000
CLIENT_PORT=3000


# =========================================================
# НАСТРОЙКИ ФРОНТЕНДА (Vite)
# =========================================================

# Базовый URL API, который будет зашит во фронт при сборке (Vite).
# ВАЖНО: это адрес, на который будет ходить БРАУЗЕР, а не контейнер.
# Обычно это http://localhost:${API_PORT}
VITE_API_URL=http://localhost:8080


# =========================================================
# НАСТРОЙКИ БАЗЫ ДАННЫХ (КОНТЕЙНЕР POSTGRES)
# =========================================================

# Имя базы данных внутри Postgres.
POSTGRES_DB=Statistics

# Имя пользователя Postgres.
POSTGRES_USER=root

# Пароль пользователя Postgres.
POSTGRES_PASSWORD=здесь нужен пароль

# Порт Postgres, проброшенный на хост.
# Внутри контейнера Postgres слушает на 5432, снаружи — на POSTGRES_PORT.
# Пример подключения с хоста: Host=localhost;Port=5432;...
POSTGRES_PORT=5432


# =========================================================
# НАСТРОЙКИ ПОДКЛЮЧЕНИЯ К БД ДЛЯ API
# =========================================================

# Хост базы данных с точки зрения приложения (API).
# В docker-compose должен совпадать с именем сервиса БД (db).
# Т.е. API будет подключаться к Postgres по адресу "db:5432".
DB_HOST=db

# Порт базы данных с точки зрения приложения (API).
# Обычно 5432 — внутренний порт контейнера Postgres.
DB_PORT=5432